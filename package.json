{
  "name": "@malkovro/openclaw-fizzy-channel",
  "version": "0.2.0",
  "type": "module",
  "description": "OpenClaw channel plugin: chat with the agent from a Fizzy card while it sits in a chosen kanban column.",
  "license": "MIT",
  "author": "Léo Figea",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "channel",
    "fizzy",
    "kanban",
    "chatbot"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malkovro/openclaw-fizzy-channel.git"
  },
  "homepage": "https://github.com/malkovro/openclaw-fizzy-channel#readme",
  "bugs": {
    "url": "https://github.com/malkovro/openclaw-fizzy-channel/issues"
  },
  "files": [
    "index.ts",
    "setup-entry.ts",
    "src/",
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild index.ts setup-entry.ts src/*.ts --outdir=dist --outbase=. --format=esm --platform=node --log-level=warning",
    "test": "npm run build && node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./setup-entry.ts",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "fizzy",
      "label": "Fizzy",
      "blurb": "Chat with OpenClaw from a Fizzy card in a chosen column."
    },
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": ">=2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "dependencies": {
    "marked": "^15.0.12"
  }
}
